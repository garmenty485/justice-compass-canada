# =============================================================================
# Justice Compass — secrets reference (template only; copy to .env is gitignored)
#
# Root .env is optional for this project. Worker secrets → wrangler / .dev.vars
# =============================================================================

# --- Cloudflare Worker secrets (do NOT put in root .env) ----------------------
# Production (deployed Worker):
#   cd cloudflare/worker
#   npx wrangler secret put DATABRICKS_SERVING_URL
#   npx wrangler secret put DATABRICKS_TOKEN
#   npx wrangler secret put API_KEY                  # optional
#   npx wrangler secret put DATABRICKS_WAREHOUSE_ID  # optional /meta docs freshness
#   npx wrangler secret put LAKEBASE_PIPELINE_RUNS_TABLE
#   npx wrangler secret put LAKEBASE_HOST
#   npx wrangler secret put LAKEBASE_DB
#   npx wrangler secret put LAKEBASE_USER
#   npx wrangler secret put LAKEBASE_PASSWORD
#   # optional: Synced Table for /meta corpus (default is "default".cases_meta_synced)
#   # npx wrangler secret put LAKEBASE_CASES_TABLE
#   # paste: default.cases_meta_synced
#
# Local `npm run dev:worker` — use cloudflare/worker/.dev.vars instead (gitignored):
#   DATABRICKS_SERVING_URL=https://YOUR-WORKSPACE.cloud.databricks.com/serving-endpoints/justice-compass-rag-endpoint/invocations
#   DATABRICKS_TOKEN=
#   API_KEY=dev-local-key
#   LAKEBASE_CASES_TABLE=default.cases_meta_synced


# --- GitHub Actions (repo Settings → Secrets; not .env) -----------------------
# GEMINI_API_KEY=
# CLOUDFLARE_API_TOKEN=
# DATABRICKS_HOST=
# DATABRICKS_TOKEN=
# DATABRICKS_REPO_ID=
# DATABRICKS_PROD_JOB_ID=


# --- Databricks (secret scope / notebook env; not root .env) ------------------
# Lakebase ROLE + PASSWORD → Databricks scope `justice-compass` (see docs/LAKEBASE.md)
# PAT for Serving → same token as Worker DATABRICKS_TOKEN above
